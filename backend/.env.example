# Server
PORT=3001
NODE_ENV=development

# Comma-separated allowed origins (required in production for cross-origin requests)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# MongoDB — replace with your connection string; never commit real credentials
MONGODB_URI=mongodb://localhost:27017/support-tickets

# Logging: debug | info | warn | error
LOG_LEVEL=info
